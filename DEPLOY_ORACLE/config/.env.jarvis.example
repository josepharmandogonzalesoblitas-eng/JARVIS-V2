# ==============================================================================
# VARIABLES DE ENTORNO PARA JARVIS V2
# Renombra este archivo a ".env.jarvis" y colócalo en /config/
# ==============================================================================

# ─── OBLIGATORIAS ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN="TU_TOKEN_DE_TELEGRAM_AQUI"
GEMINI_API_KEY="TU_API_KEY_DE_GEMINI_AQUI"
TELEGRAM_USER_ID="TU_ID_DE_USUARIO_AQUI"

# ─── OPCIONALES (V2 — Nuevas Funcionalidades) ─────────────────────────────────

# Clima: Obtener de https://openweathermap.org/api (plan gratuito)
# Si no se configura, el check-in matutino no incluirá el clima.
OPENWEATHER_API_KEY="TU_API_KEY_OPENWEATHER_AQUI"
OPENWEATHER_CIUDAD="Lima"   # Ciudad por defecto para el clima

# TTS: La voz usa gTTS (Google TTS, sin costo). No requiere API key.
# Idioma de voz (código ISO 639-1): es=español, en=inglés, pt=portugués
TTS_IDIOMA="es"
TTS_LENTA="false"   # "true" para voz más lenta (útil en idiomas extranjeros)

# Google Calendar / Tasks (opcional, si usas el módulo de agenda)
GOOGLE_CALENDAR_ID="primary"
GOOGLE_CREDENTIALS_PATH="credentials.json"


